# Salin file ini menjadi ".env" lalu isi dengan API key Anda sendiri
# JANGAN commit file .env yang sudah berisi key asli ke Git/public repo!

# Cara dapat GEMINI_API_KEY (GRATIS, tanpa kartu kredit):
# 1. Buka https://aistudio.google.com/apikey
# 2. Login dengan akun Google Anda
# 3. Klik "Create API Key"
# 4. Copy key-nya (formatnya AIzaSy...) dan tempel di bawah ini

GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=
DATABASE_URL=sqlite:///./stress_app.db
